# Ethereum mainnet HTTPS RPC endpoint (Ankr)
ETH_RPC_URL=https://rpc.ankr.com/eth/f476bf...

# Deployer / owner wallet private key (used by Foundry scripts, NOT the keeper)
PRIVATE_KEY=0xac998...

# Etherscan API key (used by Foundry verification scripts)
ETHERSCAN_API_KEY=EATX16...

# ── Keeper Daemon ─────────────────────────────────────────────────────────────

# 32-byte hex private key for the dedicated keeper wallet (0x-prefixed)
KEEPER_PRIVATE_KEY=0x...

# Comma-separated list of Yearn V3 strategy contract addresses to harvest
STRATEGY_ADDRESSES=0x80c...

# Seconds between full harvest cycles across all strategies
HARVEST_INTERVAL_SECONDS=86400

# Skip the entire cycle if baseFeePerGas (in gwei) exceeds this value
MAX_GAS_PRICE_GWEI=30

# EIP-1559 max priority fee (tip) per gas in gwei
MAX_PRIORITY_FEE_GWEI=2

# Retry policy: exponential (Option A) or fixed_cooldown (Option B)
RETRY_POLICY=exponential

# [Option A] Initial retry delay in seconds (doubles each failure)
BASE_RETRY_DELAY_SECONDS=3600

# [Option A] Maximum retry delay cap in seconds
MAX_RETRY_DELAY_SECONDS=86400

# [Option A] Number of consecutive failures before strategy is SUSPENDED
MAX_RETRY_ATTEMPTS=3

# [Option B] Fixed cooldown window in seconds after each failure
RETRY_COOLDOWN_SECONDS=21600

# [Option B] Number of cooldown cycles before strategy is SUSPENDED
MAX_COOLDOWN_CYCLES=4

# ── Harvest profitability guard ───────────────────────────────────────────────

# Only execute report() when the estimated gas cost is less than this fraction
# of the expected profit. Expressed in basis points (100 bps = 1%).
# Example: 500 = gas must be < 5% of profit (profit must be 20x gas cost).
# Set to 0 to disable the check and harvest unconditionally.
MIN_PROFIT_RATIO_BPS=500

# ETH/USD price in cents used to compare gas cost (in ETH) against profit (in
# stablecoin USD). Update this periodically to reflect current market price.
# Example: 300000 = $3000.00 per ETH
ETH_USD_PRICE_CENTS=300000