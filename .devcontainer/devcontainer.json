{
  // Name shown in the VS Code UI bottom-left corner.
  "name": "Curve Keeper Daemon (C++20)",

  "workspaceFolder": "/workspaces/keeperdaemoncpp",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/keeperdaemoncpp,type=bind,consistency=cached",

  "build": {
    "dockerfile": "Dockerfile",
    // ".." lets the Dockerfile COPY from the repo root.
    "context": ".."
  },

  // SYS_PTRACE + seccomp=unconfined are required for gdb to attach.
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined",
    // Lets the container use the host's inter-process communication namespace, 
    // helpful for shared memory performance or specific multi-process scenarios.
    "--ipc=host"
  ],

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        // Use clangd instead of ms-cpptools IntelliSense to avoid conflicts.
        "C_Cpp.intelliSenseEngine": "disabled",
        "cmake.buildDirectory": "${workspaceFolder}/build"
      },
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "llvm-vs-code-extensions.vscode-clangd"
      ]
    }
  },

  "remoteUser": "vscode",

  // Runs once after the container is created.
  // Installs all Conan + FetchContent dependencies so the first build is fast.
  "postCreateCommand": "make deps"
}